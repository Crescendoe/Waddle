---
/* Footer */
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/images/wade_wave.png" alt="Waddle" />
          Waddle
        </div>
        <p>
          Your fun hydration companion. Track water, collect ducks, complete challenges,
          and build the healthiest habits — one sip at a time.
        </p>
      </div>

      <div class="footer-column">
        <h4>Product</h4>
        <ul>
          <li><a href="#features">Features</a></li>
          <li><a href="#tracking">Drink Tracking</a></li>
          <li><a href="#ducks">Duck Companions</a></li>
          <li><a href="#challenges">Challenges</a></li>
          <li><a href="#screenshots">Screenshots</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4>More</h4>
        <ul>
          <li><a href="#progress">XP & Leagues</a></li>
          <li><a href="#themes">Themes</a></li>
          <li><a href="#quests">Daily Quests</a></li>
          <li><a href="#download">Download</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of Service</a></li>
          <li><a href="mailto:support@waddleapp.com">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; {currentYear} Waddle. All rights reserved.</span>
      <div class="footer-social">
        <a href="#" aria-label="Twitter">𝕏</a>
        <a href="#" aria-label="Instagram">📷</a>
        <a href="https://github.com/Crescendoe/Waddle" aria-label="GitHub">⌨</a>
      </div>
    </div>
  </div>
</footer>
