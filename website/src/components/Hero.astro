---
/* Hero Section */
---

<section class="hero" id="home">
  <!-- Floating Droplets -->
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>

  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="hero-title font-display">
        Stay Hydrated.<br/>Stay Happy.
      </h1>
      <p class="hero-subtitle">
        Meet <strong>Waddle</strong> — the adorable hydration tracker with duck companions,
        challenges, streaks, and 70+ beverages to keep you on track every day.
      </p>
      <div class="hero-buttons">
        <a href="#download" class="btn btn-primary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Now
        </a>
        <a href="#features" class="btn btn-outline">
          Explore Features
        </a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="hero-stat-number">70+</div>
          <div class="hero-stat-label">Beverages</div>
        </div>
        <div>
          <div class="hero-stat-number">24</div>
          <div class="hero-stat-label">Duck Companions</div>
        </div>
        <div>
          <div class="hero-stat-number">48</div>
          <div class="hero-stat-label">Themes</div>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <!-- Phone Mockup -->
      <div class="phone-mockup">
        <!-- Front face: screen -->
        <div class="phone-front">
          <div class="phone-screen">
            <div class="phone-notch"></div>
            <video
              src="/images/screenshots/home_demo.webm"
              autoplay
              loop
              muted
              playsinline
              poster="/images/screenshots/home_screen.png"
              style="width:100%; height:100%; object-fit:cover;"
            ></video>
          </div>
        </div>
        <!-- Back face: phone rear -->
        <div class="phone-back">
          <div class="phone-back-camera">
            <div class="camera-lens"></div>
            <div class="camera-lens camera-lens-small"></div>
            <div class="camera-flash"></div>
          </div>
          <div class="phone-back-logo">
            <img src="/images/wade_wave.png" alt="Waddle" style="width:90px; opacity:0.7;" />
          </div>
        </div>
        <!-- 3D body slices stacked in Z for curved depth -->
        <div class="phone-body-slice" style="--z: 7px"></div>
        <div class="phone-body-slice" style="--z: 6px"></div>
        <div class="phone-body-slice" style="--z: 5px"></div>
        <div class="phone-body-slice" style="--z: 4px"></div>
        <div class="phone-body-slice" style="--z: 3px"></div>
        <div class="phone-body-slice" style="--z: 2px"></div>
        <div class="phone-body-slice" style="--z: 1px"></div>
        <div class="phone-body-slice" style="--z: 0px"></div>
        <div class="phone-body-slice" style="--z: -1px"></div>
        <div class="phone-body-slice" style="--z: -2px"></div>
        <div class="phone-body-slice" style="--z: -3px"></div>
        <div class="phone-body-slice" style="--z: -4px"></div>
        <div class="phone-body-slice" style="--z: -5px"></div>
        <div class="phone-body-slice" style="--z: -6px"></div>
        <div class="phone-body-slice" style="--z: -7px"></div>
      </div>
      <!-- Floating ducks -->
      <img src="/images/wade_flying.png" alt="Wade flying" class="hero-duck hero-duck-main" />
      <img src="/images/wade_floating.png" alt="Wade floating" class="hero-duck hero-duck-small" />
    </div>
  </div>

  <!-- Wave layers -->
  <div class="hero-waves">
    <div class="wave wave-1"></div>
    <div class="wave wave-2"></div>
    <div class="wave wave-3"></div>
  </div>
</section>
