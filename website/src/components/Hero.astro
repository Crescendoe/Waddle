---
/* Hero Section */
---

<section class="hero" id="home">
  <!-- Floating Droplets -->
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>

  <div class="container hero-content">
    <div class="hero-text">
      <span class="badge hero-badge">🦆 Hydration Made Fun</span>
      <h1 class="hero-title font-display">
        Stay Hydrated.<br/>Stay Happy.
      </h1>
      <p class="hero-subtitle">
        Meet <strong>Waddle</strong> — the adorable hydration tracker with duck companions,
        challenges, streaks, and 70+ beverages to keep you on track every day.
      </p>
      <div class="hero-buttons">
        <a href="#download" class="btn btn-primary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Now
        </a>
        <a href="#features" class="btn btn-outline">
          Explore Features
        </a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="hero-stat-number">70+</div>
          <div class="hero-stat-label">Beverages</div>
        </div>
        <div>
          <div class="hero-stat-number">24</div>
          <div class="hero-stat-label">Duck Companions</div>
        </div>
        <div>
          <div class="hero-stat-number">48</div>
          <div class="hero-stat-label">Themes</div>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <!-- Phone Mockup -->
      <div class="phone-mockup">
        <div class="phone-screen">
          <div class="phone-notch"></div>
          <div class="screenshot-placeholder">
            <div class="placeholder-icon">💧</div>
            <span>Home Screen<br/><em style="font-size:0.75rem;opacity:0.6;">Place screenshot: home_screen.png</em></span>
          </div>
        </div>
      </div>
      <!-- Floating ducks -->
      <img src="/images/wade_flying.png" alt="Wade flying" class="hero-duck hero-duck-main" />
      <img src="/images/wade_floating.png" alt="Wade floating" class="hero-duck hero-duck-small" />
    </div>
  </div>

  <!-- Wave layers -->
  <div class="hero-waves">
    <div class="wave wave-1"></div>
    <div class="wave wave-2"></div>
    <div class="wave wave-3"></div>
  </div>
</section>
