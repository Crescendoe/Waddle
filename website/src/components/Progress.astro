---
/* Streaks, XP, and Leagues */
const streakTiers = [
  { name: 'Bronze', days: '3+', color: '#CD7F32', icon: '🥉' },
  { name: 'Silver', days: '7+', color: '#C0C0C0', icon: '🥈' },
  { name: 'Gold', days: '14+', color: '#FFD700', icon: '🥇' },
  { name: 'Platinum', days: '30+', color: '#36708B', icon: '💎' },
  { name: 'Diamond', days: '60+', color: '#42A5F5', icon: '💠' },
  { name: 'Obsidian', days: '100+', color: '#2C2C2C', icon: '🖤' },
];

const leagues = [
  { name: 'Puddle', icon: '🟤', color: '#8D6E63', bg: 'rgba(141,110,99,0.1)', desc: 'Starting tier — begin your journey' },
  { name: 'Stream', icon: '🔵', color: '#42A5F5', bg: 'rgba(66,165,245,0.1)', desc: 'Top 3 advance from Puddle' },
  { name: 'River', icon: '🟢', color: '#66BB6A', bg: 'rgba(102,187,106,0.1)', desc: 'Consistent hydrators rise here' },
  { name: 'Lake', icon: '🟣', color: '#AB47BC', bg: 'rgba(171,71,188,0.1)', desc: 'Elite competitors only' },
  { name: 'Ocean', icon: '🟡', color: '#FFD700', bg: 'rgba(255,215,0,0.1)', desc: 'The ultimate league tier' },
];

const xpEvents = [
  { action: 'Log a drink', xp: '+10 XP' },
  { action: 'Healthy pick', xp: '+5 XP' },
  { action: 'Daily goal met', xp: '+50 XP' },
  { action: 'Complete quest', xp: '+30 XP' },
  { action: 'All quests done', xp: '+50 XP' },
  { action: 'Challenge done', xp: '+200 XP' },
  { action: 'Streak milestone', xp: '+100 XP' },
  { action: 'First drink of day', xp: '+5 XP' },
];
---

<section class="progress-section" id="progress">
  <div class="container">
    <div style="text-align: center;">
      <span class="section-badge" style="background: rgba(255,215,0,0.1); color: #f57f17;">🔥 Level Up</span>
      <h2 class="section-title">Streaks, XP & Leagues</h2>
      <p class="section-subtitle">
        Build unstoppable streaks, earn XP from every action, level up to 100, and compete in weekly leagues against other hydrators.
      </p>
    </div>

    <div class="progress-layout">
      <!-- Left Column: Streaks + Leagues -->
      <div class="reveal-left" style="display:flex; flex-direction:column; gap:32px;">
        <!-- Streak Tiers -->
        <div>
          <h3 style="font-size:1.3rem; color: var(--primary-dark); margin-bottom:16px;">🔥 Streak Tiers</h3>
          <div class="streak-tiers stagger-children">
            {streakTiers.map((tier) => (
              <div class="tier-item reveal" style={`border-left: 4px solid ${tier.color};`}>
                <div class="tier-icon" style={`background: ${tier.color}15; font-size: 1.5rem;`}>{tier.icon}</div>
                <div class="tier-info">
                  <h4 style={`color: ${tier.color};`}>{tier.name}</h4>
                  <p>{tier.days} days streak</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Leagues -->
        <div>
          <h3 style="font-size:1.3rem; color: var(--primary-dark); margin-bottom:16px;">🏅 Weekly Leagues</h3>
          <div class="league-tiers stagger-children">
            {leagues.map((league) => (
              <div class="league-item reveal" style={`border-left: 4px solid ${league.color};`}>
                <div class="league-icon" style={`background: ${league.bg};`}>{league.icon}</div>
                <div class="league-info">
                  <h4>{league.name}</h4>
                  <p>{league.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right Column: XP System -->
      <div class="reveal-right" style="display:flex; flex-direction:column; gap:24px;">
        <div class="xp-showcase">
          <h3>⚡ XP & Leveling — Max Level 100</h3>
          <p style="opacity:0.8; font-size:0.92rem; margin-bottom:8px;">
            Every sip earns XP. Level up to unlock new themes, earn Drops, and climb the leaderboard.
          </p>
          <div class="xp-bar-track">
            <div class="xp-bar-fill"></div>
          </div>
          <p style="font-size:0.85rem; opacity:0.7; margin-bottom:20px;">Level 42 — 2,340 / 3,600 XP</p>
          <div class="xp-events">
            {xpEvents.map((e) => (
              <div class="xp-event">
                <span>{e.action}</span>
                <span class="xp-amount">{e.xp}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Shop Preview -->
        <div class="glass-card" style="padding:28px;">
          <h3 style="font-size:1.3rem; color:var(--primary-dark); margin-bottom:16px;">🏪 The Shop</h3>
          <div style="display:flex; flex-direction:column; gap:12px;">
            <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; border-radius:12px; background:rgba(108,204,209,0.08);">
              <div>
                <div style="font-weight:600; font-size:0.95rem;">❄️ Streak Freeze</div>
                <div style="font-size:0.82rem; color:var(--text-hint);">Auto-preserves your streak</div>
              </div>
              <span style="font-weight:700; color:var(--water-dark);">100 💧</span>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; border-radius:12px; background:rgba(108,204,209,0.08);">
              <div>
                <div style="font-weight:600; font-size:0.95rem;">⚡ Double XP</div>
                <div style="font-size:0.82rem; color:var(--text-hint);">2× XP until midnight</div>
              </div>
              <span style="font-weight:700; color:var(--water-dark);">200 💧</span>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; border-radius:12px; background:rgba(108,204,209,0.08);">
              <div>
                <div style="font-weight:600; font-size:0.95rem;">⏩ Quick Sip</div>
                <div style="font-size:0.82rem; color:var(--text-hint);">Skip cooldown timer</div>
              </div>
              <span style="font-weight:700; color:var(--water-dark);">50 💧</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
